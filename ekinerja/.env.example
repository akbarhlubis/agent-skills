# E-Kinerja PaperlessHospital Credentials
# Copy this file to .env and fill in your credentials
# .env is gitignored — never commit it!

EKNERJA_EMAIL=your-email@example.com
EKNERJA_PASSWORD=your-password

# Hospital-specific settings (opsional — sesuaikan RS masing-masing)
# Cara menemukan: buka form create task, ketik di autocomplete, catat hasilnya
EKNERJA_RS_SEARCH=Batin
EKNERJA_RS_NAME=RS Umum Daerah Batin Mangunang
EKNERJA_PERMINTAAN_SEARCH=SIMRS
EKNERJA_PERMINTAAN_NAME=Instalasi SIMRS (IT)
